generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)
  shops     Shop[]
}

model Shop {
  id        String   @id @default(uuid())
  shopName  String
  ownerName String
  mobile    String
  address   String?
  latitude  Float?
  longitude Float?
  routeId   String
  createdAt DateTime @default(now())
  route     Route    @relation(fields: [routeId], references: [id])
}

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique
  name            String
  gst             Float
  caseSize        Int
  createdAt       DateTime @default(now())
  distributorRate Float
  hsnCode         String
  isActive        Boolean  @default(true)
  mrp             Float
  reorderLevel    Int
  retailerRate    Float
  shelfLifeDays   Int?
  trackBatch      Boolean  @default(true)
  trackMfgDate    Boolean  @default(true)
  imageUrl        String?
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ACCOUNTANT
  GODOWN
  SALESMAN
  DELIVERY
}
